100 S=1:PI=3.14159
110 FOR C=0 TO 99
120 H=C*0.01
130 V=0.75+COS(6*PI*H)*0.25
140 GOSUB 200
150 OUT &H20,&HFF*R:OUT &H21,&HFF*G
160 OUT &H22,&HFF*B:OUT &H23,&HC0
170 NEXT C:GOTO 110
200 R=V:G=V:B=V:A=H*6:I=INT(A):F=A-I
210 ON I+1 GOTO 220,230,240,250,260,270
220 G=G*(1-S*(1-F)):B=B*(1-S      ):RETURN
230 R=R*(1-S*   F ):B=B*(1-S      ):RETURN
240 R=R*(1-S      ):B=B*(1-S*(1-F)):RETURN
250 R=R*(1-S      ):G=G*(1-S*   F ):RETURN
260 R=R*(1-S*(1-F)):G=G*(1-S      ):RETURN
270 G=G*(1-S      ):B=B*(1-S*   F ):RETURN
