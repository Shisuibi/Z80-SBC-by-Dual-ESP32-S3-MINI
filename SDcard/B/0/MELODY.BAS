100 PRINT "1. XEVIOUS":PRINT "2. Elevator Action":PRINT
110 PRINT "BGM Number";:INPUT M
120 IF M=1 THEN GOTO 200
130 IF M=2 THEN GOTO 300
140 END
200 REM ---- XEVIOUS (C) 1983 NAMCO ----
210 M$="N4T150"                      :GOSUB 1000
220 M$="O6C6O7C6O6B6O7C6E6C6O6B6O7C6":GOSUB 1000
230 M$="O6C6O7C6O6a6O7C6E6C6O6a6O7C6":GOSUB 1000
240 M$="O6C6O7C6O6A6O7C6E6C6O6A6O7C6":GOSUB 1000
250 M$="O6C6O7C6O6g6O7C6E6C6O6g6O7C6":GOSUB 1000:GOTO 220
300 REM ---- Elevator Action (C) 1983 TAITO ----
310 M$="N4T120"                          :GOSUB 1000
320 M$="O5E8R5E8R8g8R8B8R8O6c8"          :GOSUB 1000
330 M$="D8c8O5B8a8B8R8R8E8R5"            :GOSUB 1000
340 M$="O5E8R5E8R8g8R8B8R8O6c8"          :GOSUB 1000
350 M$="D8c8O5B8g8E8R8R4"                :GOSUB 1000
360 M$="O5E8R5E8R8g8R8B8R8O6c8"          :GOSUB 1000
370 M$="D8c8O5B8a8B8R8R8E8R5"            :GOSUB 1000
380 M$="O5E8R5E8R8g8R8B8R8O6c8"          :GOSUB 1000
390 M$="D8c8O5B8g8E8R8c3E3f3"            :GOSUB 1000
400 M$="O5G8G6g6G8G6g6B8B6A6g8g6E6"      :GOSUB 1000
410 M$="g8g6A6g8g6B6R5B8B6R5B6R5B3O6c3d3":GOSUB 1000
420 M$="E4g4A3A3g3E3E3O5B3"              :GOSUB 1000
430 M$="O6E3D3O5B3O6d3d3E3E4E8R8"        :GOSUB 1000:GOTO 320
1000 REM ---- Tiny MML for Z80-SBC ----
1010 P=1:L=LEN(M$)
1100 IF P>L THEN RETURN
1110 IF MID$(M$,P,1)="N" THEN GOTO 1400
1120 IF MID$(M$,P,1)="T" THEN GOTO 1500
1130 IF MID$(M$,P,1)="O" THEN GOTO 1600
1140 IF MID$(M$,P,1)="R" THEN D=  &H00:GOTO 1700
1200 IF MID$(M$,P,1)="C" THEN D=O+&H00:GOTO 1700
1210 IF MID$(M$,P,1)="c" THEN D=O+&H01:GOTO 1700
1220 IF MID$(M$,P,1)="D" THEN D=O+&H02:GOTO 1700
1230 IF MID$(M$,P,1)="d" THEN D=O+&H03:GOTO 1700
1240 IF MID$(M$,P,1)="E" THEN D=O+&H04:GOTO 1700
1250 IF MID$(M$,P,1)="F" THEN D=O+&H05:GOTO 1700
1260 IF MID$(M$,P,1)="f" THEN D=O+&H06:GOTO 1700
1270 IF MID$(M$,P,1)="G" THEN D=O+&H07:GOTO 1700
1280 IF MID$(M$,P,1)="g" THEN D=O+&H08:GOTO 1700
1290 IF MID$(M$,P,1)="A" THEN D=O+&H09:GOTO 1700
1300 IF MID$(M$,P,1)="a" THEN D=O+&H0A:GOTO 1700
1310 IF MID$(M$,P,1)="B" THEN D=O+&H0B:GOTO 1700
1400 N=VAL(MID$(M$,P+1,1)):P=P+2
1410 GOTO 1100
1500 T=VAL(MID$(M$,P+1,3)):P=P+4
1510 S1=INT(N*60/T):C1=INT(N*6000/T-S1*100)
1520 S2=INT( 120/T):C2=INT( 12000/T-S2*100)
1530 S3=INT(  20/T):C3=INT(  2000/T-S3*100)
1540 S4=INT(  60/T):C4=INT(  6000/T-S4*100)
1550 S5=INT(   0/T):C5=INT(     0/T-S5*100)
1560 S6=INT(  15/T):C6=INT(  1500/T-S6*100)
1570 S8=INT(  30/T):C8=INT(  3000/T-S8*100)
1580 GOTO 1930
1600 O=VAL(MID$(M$,P+1,1))*&H10:P=P+2
1610 GOTO 1100
1700 R=VAL(MID$(M$,P+1,1)):P=P+2
1710 ON R GOTO 1800,1810,1820,1830,1840,1850,1800,1860
1800 S=S1:C=C1:GOTO 1900
1810 S=S2:C=C2:GOTO 1900
1820 S=S3:C=C3:GOTO 1900
1830 S=S4:C=C4:GOTO 1900
1840 S=S5:C=C5:GOTO 1900
1850 S=S6:C=C6:GOTO 1900
1860 S=S8:C=C8:GOTO 1900
1900 OUT &H10,D:IF S=0 THEN GOTO 1920
1910 IF INP(&H19)<S THEN GOTO 1910
1920 IF INP(&H18)<C THEN GOTO 1920
1930 OUT &H19,0:OUT &H18,0:GOTO 1100
